generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(uuid())
  name           String
  email          String          @unique
  password       String
  role           Role            @default(STUDENT)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  payments       Payment[]
  supportTickets SupportTicket[]
  progress       UserProgress[]
}

model Course {
  id          String   @id @default(uuid())
  title       String
  description String
  price       Float
  lessons     Int      @default(0)
  createdAt   DateTime @default(now())
}

model Payment {
  id             String        @id @default(uuid())
  userId         String
  courseTitle    String        @default("Especialista en Compliance")
  amount         Float
  status         PaymentStatus @default(PENDIENTE)
  comprobanteUrl String?
  imageName      String?
  date           DateTime      @default(now())
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SupportTicket {
  id                 String          @id
  userId             String
  title              String
  description        String
  status             TicketStatus    @default(ABIERTO)
  image              String?
  adminAgreedToClose Boolean         @default(false)
  devAgreedToClose   Boolean         @default(false)
  date               DateTime        @default(now())
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages           TicketMessage[]
}

model TicketMessage {
  id       String        @id
  ticketId String
  sender   String
  text     String
  image    String?
  devName  String?
  date     DateTime      @default(now())
  ticket   SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  EDITOR
  STUDENT
}

enum PaymentStatus {
  PENDIENTE
  APROBADO
  RECHAZADO
}

enum TicketStatus {
  ABIERTO
  RESUELTO
}

model UserProgress {
  id         String   @id @default(uuid())
  userId     String
  courseId   String
  lessonKey  String   // Formato "moduloIdx_leccionIdx"
  completed  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId, lessonKey])
}

